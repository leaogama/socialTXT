LLM_API_KEY=sua_chave_openrouter_ou_compatível
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=deepseek/deepseek-chat-v3-0324
# Proxy residencial para contornar bloqueios do YouTube em IPs de datacenter/cloud
# Formatos aceitos: http://user:pass@host:port | socks5://user:pass@host:port
PROXY_URL=

# Opção de fallback: usar perfil persistente do navegador para manter cookies (true/false)
USE_BROWSER_PROFILE=false
BROWSER_PROFILE_PATH=/app/data/browser-profile

# Modo Login Visual na VPS (VNC) - Compartilha os cookies salvos no container browser-login
ENABLE_VNC_BROWSER=false
